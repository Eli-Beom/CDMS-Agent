{
  "manifest_version": 3,
  "name": "CDMS Agent",
  "version": "0.1.0",
  "description": "Chrome extension bridge for local-first CDMS validation automation.",
  "permissions": ["storage", "tabs", "activeTab", "sidePanel", "scripting", "debugger"],
  "host_permissions": [
    "*://sbx.cdms.mavenclinical.com/*",
    "*://cdms.mavenclinical.com/*",
    "http://127.0.0.1:3200/*",
    "http://localhost:3200/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "CDMS Agent"
  },
  "content_scripts": [
    {
      "matches": ["*://sbx.cdms.mavenclinical.com/*", "*://cdms.mavenclinical.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
